# Anthropic API key for Claude Vision (server-side only)
ANTHROPIC_API_KEY=sk-ant-api03-...

# App configuration
NEXT_PUBLIC_APP_URL=https://highlightmagic.app
NEXT_PUBLIC_IOS_APP_STORE_URL=https://apps.apple.com/app/highlight-magic/id0000000000

# Atlas Cloud API key for Kling 3.0 photo animation (server-side only)
ATLASCLOUD_API_KEY=

# ElevenLabs API key for Eleven Music AI generation (server-side only, Pro feature)
ELEVENLABS_API_KEY=

# Optional: Cloudinary for video processing
# CLOUDINARY_CLOUD_NAME=
# CLOUDINARY_API_KEY=
# CLOUDINARY_API_SECRET=

# ── P0: server-side entitlement + quota (owner-provisioned) ──
# Durable quota store so the free limit holds across serverless instances.
# Without these the gate falls back to in-memory (per-instance only — NOT durable in prod).
# KV_REST_API_URL=
# KV_REST_API_TOKEN=
# App Store Server API creds for SERVER-SIDE Pro verification (never trust a client flag).
# Until all three are set, every user is treated as free-tier and the monthly limit is enforced.
# APP_STORE_ISSUER_ID=
# APP_STORE_KEY_ID=
# APP_STORE_PRIVATE_KEY=
